# Dependencies / build output
node_modules/
dist/
target/
coverage/
logs/
*.log
test-artifacts/

# The local sibling-library link (the npm analog of the bridge's gitignored
# .cargo/config.toml paths override): `npm run link:lib` generates local/edgecommons,
# a zero-dependency workspace stub that satisfies @edgecommons/edgecommons from the
# sibling checkout at ../core/libs/ts. CI has no local/ and resolves the
# published package instead.
local/
proto/

# The lockfile is deliberately untracked while the sibling link is the dev path:
# it would record the local/edgecommons stub, which does not exist in CI. Revisit
# (commit it) when the console pins the published @edgecommons/edgecommons release.
package-lock.json

# Runtime artifacts (house rule: never commit .vault, caches, TLS certs)
.vault/
.codex-tmp/
*.pem
*.key

# Gemba TV experiment build output
experiments/gemba/tv/google-tv-gemba/.gradle/
experiments/gemba/tv/google-tv-gemba/build/
experiments/gemba/tv/google-tv-gemba/app/build/
experiments/gemba/tv/tizen-gemba/.buildResult/
