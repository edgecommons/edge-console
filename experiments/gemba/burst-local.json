{
  "logging": {
    "level": "INFO"
  },
  "heartbeat": {
    "enabled": true,
    "intervalSecs": 5
  },
  "messaging": {
    "local": {
      "host": "127.0.0.1",
      "port": 1883,
      "clientId": "edge-console-gemba-burst-local"
    },
    "requestTimeoutSeconds": 30
  },
  "hierarchy": {
    "levels": ["site", "device"]
  },
  "identity": {
    "site": "gemba-lab"
  },
  "component": {
    "token": "edge-console-gemba-burst-experiment",
    "global": {
      "console": {
        "ws": {
          "port": 18444,
          "bindAddress": "127.0.0.1",
          "heartbeatIntervalMs": 15000,
          "allowedOrigins": []
        },
        "apps": [
          {
            "id": "andon",
            "webRoot": "experiments/gemba/apps/andon",
            "allowedOrigins": ["http://127.0.0.1:15174"],
            "allowedRoles": ["viewer"],
            "capabilities": ["signals", "alarms"]
          },
          {
            "id": "gemba-board",
            "webRoot": "experiments/gemba/apps/gemba-board",
            "allowedOrigins": ["http://127.0.0.1:15175"],
            "allowedRoles": ["viewer"],
            "capabilities": ["fleet", "events", "attributes"]
          },
          {
            "id": "restricted",
            "webRoot": "experiments/gemba/apps/andon",
            "allowedOrigins": ["http://127.0.0.1:15176"],
            "allowedRoles": ["operator"],
            "capabilities": ["signals"]
          }
        ],
        "runtime": {
          "workerThreads": 4,
          "mallocArenaMax": 2,
          "eventBufferCapacity": 512
        },
        "rbac": {
          "defaultRole": "viewer",
          "roles": {
            "viewer": {
              "allow": ["ping", "describe", "get-configuration", "sb/status", "sb/browse", "sb/read"],
              "deny": []
            },
            "operator": {
              "allow": ["*"],
              "deny": []
            }
          }
        }
      }
    },
    "instances": [{ "id": "main" }]
  }
}
