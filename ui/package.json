{
  "name": "@edgecommons/edge-console-ui",
  "version": "0.1.0",
  "description": "Edge Console UI: the IBM Carbon/React front end. Slice C3 ships the edge-health view (priority #1) over the C2 WS gateway; config-review (C5) and events/metrics (C6) follow.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@carbon/react": "^1.78.0",
    "@edgecommons/edge-console-protocol": "^0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^26.0.0",
    "sass-embedded": "^1.83.0",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
